<Page x:Class="docker_rep2_win.PageMenu"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:docker_rep2_win"
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="600"
      Title="Menu" Focusable="True">

    <Grid Background="#F3F3F3">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="30,30,30,10">
            <TextBlock Text="ステータス" 
                       FontSize="16" FontWeight="Bold" 
                       Foreground="#333333" VerticalAlignment="Center"/>
            <Border x:Name="StatusIndicator" Margin="20,0,0,0" Padding="12,5" CornerRadius="15" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="StatusDot" Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusLabel" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border x:Name="CertInfoIndicator" Margin="20,0,0,0" Padding="12,5" CornerRadius="15" VerticalAlignment="Center" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔒 " FontSize="14" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtCertInfo" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <UniformGrid Grid.Row="1" Columns="2" Margin="20" KeyboardNavigation.DirectionalNavigation="Cycle" KeyboardNavigation.TabNavigation="Cycle">
            <Button x:Name="BtnStart" Content="開始" Click="Start_Click" Margin="10" Padding="15" FontSize="16"
                    Style="{StaticResource PageButtonStyle}" Background="#F4FAF4" BorderBrush="#CCE8CC" Tag="#E9F5E9">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="5,0">
                            <TextBlock Text="▶️" FontSize="24" Margin="0,0,15,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>

            <Button x:Name="BtnStop" Content="停止" Click="Stop_Click" Margin="10" Padding="15" FontSize="16"
                    Style="{StaticResource PageButtonStyle}" Background="#FAF4F4" BorderBrush="#E8CCCC" Tag="#F5E9E9">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="5,0">
                            <TextBlock Text="🛑" FontSize="24" Margin="0,0,15,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>

            <Button x:Name="BtnBrowser" Content="ブラウザで開く" Click="OpenBrowser_Click" Margin="10" Padding="15" FontSize="16"
                    Style="{StaticResource PageButtonStyle}" Background="#F4F4FA" BorderBrush="#CCCCE8" Tag="#E9E9F5">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="5,0">
                            <TextBlock Text="🌐" FontSize="24" Margin="0,0,15,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>

            <Button x:Name="BtnTerminal" Content="ターミナル" Click="Terminal_Click" Margin="10" Padding="15" FontSize="16"
                    Style="{StaticResource PageButtonStyle}" Background="#F4FAFA" BorderBrush="#CCE8E8" Tag="#E9F5F5">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="5,0">
                            <TextBlock Text="💻" FontSize="24" Margin="0,0,15,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>

            <Button x:Name="BtnConfig" Content="設定" Click="Config_Click" Margin="10" Padding="15" FontSize="16"
                    Style="{StaticResource PageButtonStyle}" Background="#F9F9F9" BorderBrush="#CCCCCC" Tag="#E9E9E9">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="5,0">
                            <TextBlock Text="⚙️" FontSize="24" Margin="0,0,15,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>

            <Button x:Name="BtnVersion" Content="バージョン" Click="Version_Click" Margin="10" Padding="15" FontSize="16"
                    Style="{StaticResource PageButtonStyle}" Background="#F9F9F9" BorderBrush="#CCCCCC" Tag="#E9E9E9">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="5,0">
                            <TextBlock Text="ℹ️" FontSize="24" Margin="0,0,15,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>

            <Button x:Name="BtnExit" Content="閉じる" Click="Exit_Click" Margin="10" Padding="15" FontSize="16"
                    Style="{StaticResource PageButtonStyle}" Background="#FFF5F5" BorderBrush="#E8CCCC" Tag="#FFEBEB">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="5,0">
                            <TextBlock Text="❌" FontSize="24" Margin="0,0,15,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>
        </UniformGrid>
    </Grid>
</Page>