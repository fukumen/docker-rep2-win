<Page x:Class="docker_rep2_win.PageConfdiff"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:docker_rep2_win"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PageConfdiff"
      Loaded="PageConfdiff_Loaded">

    <Grid Background="White" Margin="20,15,20,15" KeyboardNavigation.DirectionalNavigation="Cycle" KeyboardNavigation.TabNavigation="Cycle">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="設定ファイルの差分 (/var/www/conf.orig vs /ext/conf)" FontSize="18" FontWeight="Bold"/>
            <TextBlock Text="※オリジナルの設定ファイルと現在の設定ファイルの差分を表示します。/ext/confの実体はデータ保存先(rep2-data)のconfの下です。" Foreground="DimGray" FontSize="11"/>
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="LightGray" BorderThickness="1" Margin="0,0,0,15">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <TextBox x:Name="TxtDiff" IsReadOnly="True" BorderThickness="0" FontFamily="Consolas, Lucida Console, Monospace" FontSize="12" AcceptsReturn="True" Text="読み込み中..."/>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnOpenConf" Style="{StaticResource PageButtonStyle}" Content="/ext/confを開く" Width="150" Height="35" Margin="0,0,10,0" Click="BtnOpenConf_Click"/>
            <Button x:Name="BtnRefresh" Style="{StaticResource PageButtonStyle}" Content="再比較" Width="100" Height="35" Margin="0,0,10,0" Click="BtnRefresh_Click"/>
            <Button x:Name="BtnBack" Style="{StaticResource PageButtonStyle}" Content="戻る" Width="100" Height="35" Click="BtnBack_Click"/>
        </StackPanel>
    </Grid>
</Page>
