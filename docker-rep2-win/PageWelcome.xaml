<Page x:Class="docker_rep2_win.PageWelcome"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:docker_rep2_win"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PageWelcome"
      Loaded="Page_Loaded">

    <Grid Background="White" KeyboardNavigation.DirectionalNavigation="Cycle" KeyboardNavigation.TabNavigation="Cycle">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock FontSize="24" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center">
                <Run Text="{x:Static local:AppInfo.AppFullName}"/>
                <Run Text=" セットアップ"/>
            </TextBlock>
            
            <Border BorderBrush="LightGray" BorderThickness="1" Padding="20" CornerRadius="5" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock x:Name="IconOS" Text="⭕" Margin="0,0,10,0"/>
                        <TextBlock Text="Windows 11 (Ver 22H2以上) の確認"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock x:Name="IconBios" Text="⭕" Margin="0,0,10,0"/>
                        <TextBlock Text="BIOS/UEFI 仮想化支援機能 (VT-x/SVM) の確認"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock x:Name="IconVirt" Text="⭕" Margin="0,0,10,0"/>
                        <TextBlock Text="仮想化機能 (Virtual Machine Platform) の確認"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock x:Name="IconWsl" Text="⭕" Margin="0,0,10,0"/>
                        <TextBlock Text="WSL2 (Windows Subsystem for Linux) の確認"/>
                    </StackPanel>
                    
                    <TextBlock x:Name="TxtError" Text="" Foreground="Red" FontSize="12" Margin="0,10,0,0" TextWrapping="Wrap" MaxWidth="400" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="BtnFix" Style="{StaticResource PageButtonStyle}" Content="不足機能を有効化する" Width="180" Height="40" Margin="0,0,10,0" Click="BtnFix_Click" IsEnabled="False"/>
                <Button x:Name="BtnEasy" Style="{StaticResource PageButtonStyle}" Content="おまかせインストール" Width="180" Height="40" Click="BtnEasy_Click" IsEnabled="False"/>
                <Button x:Name="BtnCustom" Style="{StaticResource PageButtonStyle}" Content="上級者向けインストール" Width="180" Height="40" Margin="10,0,0,0" Click="BtnCustom_Click" IsEnabled="False"/>
                <Button x:Name="BtnCancel" Style="{StaticResource PageButtonStyle}" Content="キャンセル" Width="120" Height="40" Margin="10,0,0,0" Click="BtnCancel_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
