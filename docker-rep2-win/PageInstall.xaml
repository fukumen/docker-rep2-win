<Page x:Class="docker_rep2_win.PageInstall"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:docker_rep2_win"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PageInstall"
      Loaded="Page_Loaded">

    <Grid Background="White" Margin="20" KeyboardNavigation.DirectionalNavigation="Cycle" KeyboardNavigation.TabNavigation="Cycle">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock x:Name="TxtTitle" Text="インストールを開始します..." FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
            
            <TextBlock x:Name="TxtSummary" TextAlignment="Center" Foreground="DimGray"/>

            <ProgressBar x:Name="PrgInstall" Width="400" Height="25" Margin="0,20,0,10" IsIndeterminate="True"/>
            <TextBlock x:Name="TxtStatus" Text="準備中..." HorizontalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,15">
            <Button x:Name="BtnCancel" Style="{StaticResource PageButtonStyle}" Content="キャンセル" Width="120" Height="35" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Page>
