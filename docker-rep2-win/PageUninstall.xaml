<Page x:Class="docker_rep2_win.PageUninstall"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:docker_rep2_win"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PageUninstall"
      Loaded="Page_Loaded">

    <Grid Background="White" Margin="20" KeyboardNavigation.DirectionalNavigation="Cycle" KeyboardNavigation.TabNavigation="Cycle">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="🗑️" FontSize="60" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10">
                <Run Text="{x:Static local:AppInfo.AppShortName}"/>
                <Run Text=" の削除"/>
            </TextBlock>
            <TextBlock HorizontalAlignment="Center" Foreground="Gray">
                <Run Text="この操作により、"/>
                <Run Text="{x:Static local:AppInfo.AppShortName}"/>
                <Run Text="が削除されます。"/>
            </TextBlock>

            <Border BorderBrush="MistyRose" BorderThickness="1" Background="#FFF9F9" Padding="20" CornerRadius="8" Margin="0,20,0,0">
                <StackPanel>
                    <CheckBox x:Name="ChkRemoveData" Content="rep2-dataも完全に削除する" Foreground="Red" IsChecked="False"/>
                    <TextBlock FontSize="11" Foreground="Gray" Margin="20,5,0,0">
                        <Run Text="※これをチェックすると"/>
                        <Run Text="{x:Static local:AppInfo.CoreAppName}"/>
                        <Run Text="の過去ログやコンフィグも消去されます。"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button Style="{StaticResource PageButtonStyle}" Content="キャンセル" Width="120" Height="40" Margin="0,0,10,0" Click="BtnCancel_Click"/>
                <Button x:Name="BtnExecute" Style="{StaticResource PageButtonStyle}" Content="アンインストール実行" Width="180" Height="40" Click="BtnExecute_Click"/>
            </StackPanel>
        </StackPanel>

        <Grid x:Name="UpdateOverlay" Background="#AA000000" Visibility="Collapsed" Margin="-20">
            <Border Background="White" CornerRadius="10" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="30,20" BorderBrush="DimGray" BorderThickness="1">
                <StackPanel HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="250" Height="12" Margin="0,0,0,15"/>
                    <TextBlock x:Name="TxtUpdateStatus" Text="アンインストール中..." FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
