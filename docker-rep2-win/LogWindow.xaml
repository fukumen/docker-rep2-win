<Window x:Class="docker_rep2_win.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ログの表示" Height="450" Width="800"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock x:Name="TxtMessage" Grid.Row="0" Margin="0,0,0,10" TextWrapping="Wrap" FontSize="14" FontWeight="SemiBold" />
        
        <Border Grid.Row="1" BorderBrush="LightGray" BorderThickness="1">
            <TextBox x:Name="TxtLog" IsReadOnly="True" AcceptsReturn="True" 
                     TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" 
                     FontFamily="Consolas, Lucida Console, Monospace" FontSize="12" BorderThickness="0" Margin="5"/>
        </Border>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="BtnCopy" Content="クリップボードにコピー" Width="150" Height="35" Margin="0,0,10,0" Click="BtnCopy_Click"/>
            <Button x:Name="BtnClose" Content="閉じる" Width="100" Height="35" Click="BtnClose_Click" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>