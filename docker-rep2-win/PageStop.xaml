<Page x:Class="docker_rep2_win.PageStop"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:docker_rep2_win"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PageStop">

    <Grid Background="#1E1E1E">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="{x:Static local:AppInfo.DockerName}" FontSize="32" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
            <TextBlock Text="Stopping..." FontSize="16" Foreground="LightGray" HorizontalAlignment="Center" Margin="0,10,0,20"/>

            <ProgressBar x:Name="PrgLoading" Width="300" Height="4" IsIndeterminate="True" Background="#333333" Foreground="#007ACC"/>
            
            <TextBlock x:Name="TxtStatus" Foreground="Gray" HorizontalAlignment="Center" Margin="20,15,20,0" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="600">
                <Run Text="{x:Static local:AppInfo.DistroName}"/>
                <Run Text="を停止中..."/>
            </TextBlock>
        </StackPanel>
    </Grid>
</Page>

